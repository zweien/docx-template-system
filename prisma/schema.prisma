// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  drafts        Draft[]
  records       Record[]
  templates     Template[]
  dataTables    DataTable[]
  dataRecords   DataRecord[]
  batchGenerations BatchGeneration[]
}

enum TemplateStatus {
  DRAFT
  READY
  ARCHIVED
}

model Template {
  id            String          @id @default(cuid())
  name          String
  description   String?
  fileName          String
  originalFileName  String          @default("")
  filePath          String
  fileSize      Int
  status        TemplateStatus  @default(DRAFT)
  createdById   String
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  dataTableId   String?
  dataTable     DataTable?      @relation(fields: [dataTableId], references: [id])
  fieldMapping  Json?
  placeholders  Placeholder[]
  drafts        Draft[]
  records       Record[]
  batchGenerations BatchGeneration[]
}

enum PlaceholderType {
  TEXT
  TEXTAREA
}

model Placeholder {
  id           String          @id @default(cuid())
  key          String
  label        String
  inputType    PlaceholderType @default(TEXT)
  required     Boolean         @default(false)
  defaultValue String?
  sortOrder    Int             @default(0)
  templateId   String
  template     Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // 数据源绑定（新增）
  sourceTableId  String?
  sourceField    String?
  enablePicker   Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  @@unique([templateId, key])
}

model Draft {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  formData   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([userId])
  @@index([templateId])
}

enum RecordStatus {
  PENDING
  COMPLETED
  FAILED
}

// ========== Master Data (Phase 2a) ==========

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT        // 单选
  MULTISELECT   // 多选
  EMAIL
  PHONE
  FILE          // 附件
  RELATION      // 关联字段
}

model DataTable {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  icon        String?
  fields      DataField[]
  records     DataRecord[]
  templates        Template[]
  batchGenerations BatchGeneration[]
  views        DataView[]
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@index([createdById])
}

model DataField {
  id           String       @id @default(cuid())
  tableId      String
  table        DataTable    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  key          String
  label        String
  type         FieldType    @default(TEXT)
  required     Boolean      @default(false)
  options      Json?
  relationTo   String?
  displayField String?
  defaultValue String?
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  @@unique([tableId, key])
}

model DataRecord {
  id          String   @id @default(cuid())
  tableId     String
  table       DataTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  data        Json
  records     Record[]
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([tableId])
  @@index([createdById])
}

model DataView {
  id            String   @id @default(cuid())
  tableId       String
  name          String
  isDefault     Boolean  @default(false)
  filters       Json?    // FilterCondition[]
  sortBy        Json?    // SortConfig | null
  visibleFields Json?    // string[]
  fieldOrder    Json?    // string[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  table         DataTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, name])
}

model Record {
  id           String       @id @default(cuid())
  templateId   String
  template     Template     @relation(fields: [templateId], references: [id])
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  formData     Json
  status       RecordStatus @default(PENDING)
  fileName     String?
  filePath     String?
  errorMessage String?
  dataRecordId String?
  dataRecord   DataRecord?  @relation(fields: [dataRecordId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  @@index([userId])
  @@index([templateId])
  @@index([status])
}

// ========== Batch Generation (Phase 2b) ==========

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OutputMethod {
  DOWNLOAD
  SAVE_TO_RECORDS
}

model BatchGeneration {
  id              String       @id @default(cuid())
  templateId      String
  template        Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dataTableId     String
  dataTable       DataTable    @relation(fields: [dataTableId], references: [id], onDelete: Cascade)
  totalCount      Int
  successCount    Int          @default(0)
  failedCount     Int          @default(0)
  status          BatchStatus  @default(PENDING)
  fileNamePattern String?
  outputMethod    OutputMethod
  createdById     String
  createdBy       User         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([templateId])
  @@index([status])
  @@index([createdById])
}
