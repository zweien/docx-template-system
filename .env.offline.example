# Copy this file to .env.offline before deployment.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
APP_PORT=8060
NEXTAUTH_URL="http://127.0.0.1:8060"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
UPLOAD_DIR="public/uploads"

# -----------------------------------------------------------------------------
# Database (reuse existing intranet PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://docx_user:change-me@10.0.0.10:5432/docx_template_system?schema=public"

# -----------------------------------------------------------------------------
# Auth mode (default: Authentik SSO)
# If you need local bypass login for troubleshooting, set both to "true".
# -----------------------------------------------------------------------------
DEV_BYPASS_AUTH="false"
NEXT_PUBLIC_DEV_BYPASS_AUTH="false"

# Authentik/OIDC
# Example issuer: http://authentik.intra.local/application/o/docx-template-system
AUTHENTIK_ISSUER="http://authentik.intra.local/application/o/docx-template-system"
AUTHENTIK_CLIENT_ID="replace-with-authentik-client-id"
AUTHENTIK_CLIENT_SECRET="replace-with-authentik-client-secret"
AUTHENTIK_LOGOUT_REDIRECT_URL="http://127.0.0.1:8060"
AUTHENTIK_ADMIN_EMAILS="admin@example.com"

# -----------------------------------------------------------------------------
# AI / model configs (optional, but keep keys valid if these features are used)
# -----------------------------------------------------------------------------
AI_PROVIDER="openai"
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL=""

# 64 hex chars each (32 bytes, AES-256-GCM)
MODEL_CONFIG_ENCRYPTION_KEY=""
API_TOKEN_ENCRYPTION_KEY=""
